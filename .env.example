# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.

# SQLite database path (relative or absolute)
DATABASE_URL=sqlite:///./data/jobs.db

# Directory where uploaded and processed files are stored
STORAGE_ROOT=./data/files

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Maximum upload size in bytes (default: 100 MB)
MAX_UPLOAD_BYTES=104857600

# File retention in seconds (default: 24 hours)
FILE_RETENTION_SECONDS=86400

# Cleanup sweep interval in seconds (default: 1 hour)
CLEANUP_INTERVAL_SECONDS=3600

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Environment label (used in log output)
ENV=development
